# ---------------------------------------------------------------------------
# Web environment. Copy to `apps/web/.env`. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Base URL of the NestJS API, used for SERVER-SIDE calls (no NEXT_PUBLIC_ prefix
# means it's never exposed to the browser bundle). The browser never talks to
# the API directly in this setup — Server Components and Server Actions do.
API_URL="http://localhost:4000/api"
