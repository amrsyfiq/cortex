# ---------------------------------------------------------------------------
# API environment. Copy to `apps/api/.env` and fill in. NEVER commit `.env`.
# These values are validated at boot by src/config/env.validation.ts — the
# server refuses to start if anything required is missing or malformed.
# ---------------------------------------------------------------------------

# Where the API listens.
PORT=4000
NODE_ENV=development

# PostgreSQL connection string (Prisma reads this).
#  - Using your LOCAL Postgres 17 (no Docker):
DATABASE_URL="postgresql://payboymacbookm2@localhost:5432/saas_app?schema=public"
#  - Using the docker-compose Postgres instead, it would be:
# DATABASE_URL="postgresql://saas:saas@localhost:5432/saas_app?schema=public"

# JWT secrets. Use long random strings in real life (e.g. `openssl rand -hex 32`).
# Two SEPARATE secrets so a leaked access secret can't forge refresh tokens.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# CORS: the web app origin allowed to call this API from the browser.
WEB_ORIGIN="http://localhost:3000"

# AI assistant (Google Gemini, free tier). OPTIONAL — the app boots without it;
# only /assistant routes need it. Get a FREE key at https://aistudio.google.com/apikey
# GEMINI_API_KEY="AIza..."
