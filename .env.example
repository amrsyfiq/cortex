# ---------------------------------------------------------------------------
# Root .env.example — copy to `.env` and adjust. Committed as a template only;
# the real `.env` is gitignored. Each app also has its own .env.example with
# app-specific keys; this root file holds values shared by docker-compose.
# ---------------------------------------------------------------------------

# PostgreSQL (used by docker-compose.yml)
POSTGRES_USER=saas
POSTGRES_PASSWORD=saas
POSTGRES_DB=saas_dashboard
POSTGRES_PORT=5432
