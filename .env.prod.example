# ===========================================================================
# PRODUCTION environment for docker-compose.prod.yml.
#
#   cp .env.prod.example .env.prod   &&   edit .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# .env.prod holds REAL SECRETS and is gitignored — never commit it. On the EC2
# box you'll create it once by hand (or have CI write it). Only THIS .example
# (no secrets) is committed.
# ===========================================================================

# --- Public domain ----------------------------------------------------------
# The hostname users visit. Caddy gets a free HTTPS cert for it automatically.
# Free option: a DuckDNS subdomain, e.g. mysaas.duckdns.org
# For LOCAL testing with no domain, set this to: localhost
DOMAIN=mysaas.duckdns.org

# Host ports Caddy publishes. Leave UNSET in production (defaults: 80 and 443).
# Only set these for local testing if something already uses 80/443, e.g.:
#   HTTP_PORT=8080
#   HTTPS_PORT=8443

# --- Container image source -------------------------------------------------
# Where to pull prebuilt images from. Defaults to ghcr.io/amrsyfiq if unset.
# IMAGE_TAG is set by CI to the commit SHA; 'latest' is fine for manual runs.
REGISTRY=ghcr.io/amrsyfiq
IMAGE_TAG=latest

# --- Postgres ---------------------------------------------------------------
# These create the database on first boot AND build the API's DATABASE_URL.
POSTGRES_USER=saas
POSTGRES_PASSWORD=CHANGE_ME_use_a_long_random_password
POSTGRES_DB=saas_app

# --- JWT secrets ------------------------------------------------------------
# Generate each with:  openssl rand -hex 32
# Two SEPARATE secrets so a leaked access secret can't forge refresh tokens.
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32_different
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- AI assistant (optional) ------------------------------------------------
# Free Google Gemini key: https://aistudio.google.com/apikey
# Leave blank to run without the /assistant features (the app still boots).
GEMINI_API_KEY=
