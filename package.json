{
  "name": "saas-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Cortex — a personal playground for experimenting with LLMs, built on a production-shaped multi-tenant dashboard (Next.js + NestJS + Prisma + PostgreSQL)",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @saas/api db:generate",
    "db:migrate": "pnpm --filter @saas/api db:migrate",
    "db:seed": "pnpm --filter @saas/api db:seed",
    "db:studio": "pnpm --filter @saas/api db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0"
  }
}
